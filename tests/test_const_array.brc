package test_const_array
using IO
block global = 1MB

fn main() {
    const i32 N = 16
    f32[N] arr

    arr[0] = 10
    arr[15] = 20

    if arr[0] != 10 { error("const array element 0") }
    if arr[15] != 20 { error("const array element 15") }

    i32 sum = 0
    i32 i = 0
    while i < N {
        arr[i] = i
        sum += 1
        i += 1
    }
    if sum != 16 { error("const array loop count") }
    if arr[7] != 7 { error("const array element 7") }
}
