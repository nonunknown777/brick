# Build: All test binaries + test alias
Import('env', 'platform_libs', 'has_hotreload', 'has_x11', 'is_cross')

test_bins = []

# ─── Helper ──────────────────────────────────────────────────
def build_test(name, sources, libs, extra_cxxflags=None):
    tc = env.Clone()
    if extra_cxxflags:
        tc.Append(CXXFLAGS=extra_cxxflags)
    bin = tc.Program(f'#build/{name}', sources, LIBS=libs)
    return bin

root_dir = Dir('#').abspath
project_root_flag = [f'-DPROJECT_ROOT=\\"{root_dir}\\"']

# ─── Unit tests ─────────────────────────────────────────────
test_bins.append(build_test('test_lexer',   ['test_lexer.cpp'],
                            ['meta_lexer']))

test_bins.append(build_test('test_parser',  ['test_parser.cpp'],
                            ['meta_parser', 'meta_lexer']))

test_bins.append(build_test('test_codegen', ['test_codegen.cpp'],
                            ['meta_codegen', 'meta_parser', 'meta_lexer'],
                            project_root_flag))

test_bins.append(build_test('test_runtime', ['test_runtime.c'],
                            ['meta_runtime']))

if has_hotreload:
    test_bins.append(build_test('test_hot_reload', ['test_hot_reload.c'],
                                ['meta_runtime']))

# ─── Window library tests (X11) ─────────────────────────────
if has_x11:
    env_win = env.Clone()
    env_win.ParseConfig('pkg-config --cflags --libs x11')

    tw = env_win.Clone()
    tw.Append(LIBS=['meta_lib_window', 'meta_runtime'])
    test_bins.append(tw.Program('#build/test_libs_window',
                                ['test_libs_window.c']))

    if has_hotreload:
        tw_hr = env_win.Clone()
        tw_hr.Append(LINKFLAGS=[
            '-rdynamic',
            '-Wl,--undefined=io_print_string',
            '-Wl,--undefined=block_alloc',
            '-Wl,--undefined=block_create_bytes',
        ])
        tw_hr.Append(LIBS=['meta_runtime'])
        tw_hr.Append(CFLAGS=[
            f'-DMETA_LIB_WINDOW_SO=\\"{root_dir}/build/meta_lib_window.so\\"'
        ])
        b = tw_hr.Program('#build/test_libs_window_hr',
                          ['test_libs_window_hr.c'])
        Depends(b, ['#build/meta_lib_window.so', '#build/libmeta_lib_window.a'])
        test_bins.append(b)

# ─── Alias: test (build + run, native only) ─────────────────
if not is_cross:
    for tb in test_bins:
        name = str(tb[0]).split('/')[-1]
        run = env.Command(f'.run_{name}', tb, str(tb[0].path))
        env.AlwaysBuild(run)
        env.Alias('test', run)

Return('test_bins')
