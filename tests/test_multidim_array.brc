package test_multidim_array
using IO
block global = 1MB

fn main() {
    // 4x4 matrix of floats
    f32[4][4] m

    m[0][0] = 1.0
    m[0][1] = 2.0
    m[1][0] = 3.0
    m[2][2] = 4.0

    f64 total = m[0][0] + m[0][1] + m[1][0] + m[2][2]
    print("total={0}", total)
    if total != 10.0 { error("multidim: total mismatch") }

    // Nested loops
    i32 cnt = 0
    i32 i = 0
    while i < 4 {
        i32 j = 0
        while j < 4 {
            m[i][j] = i * 4 + j
            cnt += 1
            j += 1
        }
        i += 1
    }

    if cnt != 16 { error("multidim: loop count") }
    if m[2][3] != 11.0 { error("multidim: element 2,3") }
    if m[3][1] != 13.0 { error("multidim: element 3,1") }
}
