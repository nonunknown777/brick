// Test virtual dispatch through vtbl for interfaces
// Testa despacho virtual via vtbl para interfaces

using IO

interface Drawable {
    fn draw(f64 dt)
    fn get_name() -> String
}

struct Circle {
    f64 radius
}

impl Circle : Drawable {
    fn draw(f64 dt) {
        print("drawing circle with radius {0} at dt {1}", radius, dt)
    }
    fn get_name() -> String {
        return "Circle"
    }
}

struct Square {
    f64 side
}

impl Square : Drawable {
    fn draw(f64 dt) {
        print("drawing square with side {0} at dt {1}", side, dt)
    }
    fn get_name() -> String {
        return "Square"
    }
}

fn main() {
    Circle c
    c.radius = 1.5
    c.draw(0.016)

    Square s
    s.side = 2.0
    s.draw(0.032)

    // Verify vtbl instances by checking struct method still works
    // These call the actual struct methods (not through the vtbl)
    String cn = c.get_name()

    String sn = s.get_name()
    // We can't compare Strings yet (no overloaded !=), just print them
    print("circle name = ")
    print(cn)
    print("\nsquare name = ")
    print(sn)
    print("\n")

    print("PASS: all vtbl dispatch tests\n")
}
