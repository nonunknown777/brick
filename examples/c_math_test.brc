include "math.h" and link m

extern fn sqrt(f64 x) -> f64
extern fn sin(f64 x) -> f64
extern fn cos(f64 x) -> f64
extern fn pow(f64 base, f64 exp) -> f64
extern fn ceil(f64 x) -> f64

using IO

fn main() {
    print("sqrt(2.0) = {0}", sqrt(2.0))
    print("sin(1.0) = {0}", sin(1.0))
    print("cos(1.0) = {0}", cos(1.0))
    print("pow(2.0, 10.0) = {0}", pow(2.0, 10.0))
    print("ceil(3.14) = {0}", ceil(3.14))
}
