package TEST

using IO

block global = 64MB

struct Player {
    int hp

    fn Player(int h) {
        hp = h
    }

    fn get_hp() -> int {
        return hp
    }

    fn take_damage(int dmg) {
        hp = hp - dmg
    }
}

struct Entity {
    int score
    Player player
}

fn print_hp(Player p) -> int {
    return p.get_hp()
}

fn main() {
    Entity e @global
    e.player.hp = 100
    int hp1 = e.player.get_hp()
    print("hp from method: ")
    print(hp1)
    e.player.take_damage(20)
    int hp2 = e.player.get_hp()
    print("hp after damage: ")
    print(hp2)
    int hp3 = print_hp(e.player)
    print("hp from function: ")
    print(hp3)
    if (hp2 == 80) {
        print("all ok")
    } else {
        print("failed")
    }
}
