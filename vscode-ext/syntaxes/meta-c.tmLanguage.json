{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Meta-C",
    "scopeName": "source.mc",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#builtin-types" },
        { "include": "#operators" },
        { "include": "#blocks-decl" },
        { "include": "#at-annotation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "match": "//.*$",
                    "name": "comment.line.double-slash.mc"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.mc",
                    "patterns": [
                        {
                            "name": "constant.character.escape.mc",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "begin": "'",
                    "end": "'",
                    "name": "string.quoted.single.mc",
                    "patterns": [
                        {
                            "name": "constant.character.escape.mc",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b[0-9]+\\.[0-9]+\\b",
                    "name": "constant.numeric.float.mc"
                },
                {
                    "match": "\\b[0-9]+\\b",
                    "name": "constant.numeric.integer.mc"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.package.mc",
                    "match": "\\b(package|using|private|public)\\b"
                },
                {
                    "name": "keyword.control.struct.mc",
                    "match": "\\b(struct|extends|interface)\\b"
                },
                {
                    "name": "keyword.control.function.mc",
                    "match": "\\b(fn|return)\\b"
                },
                {
                    "name": "keyword.control.flow.mc",
                    "match": "\\b(if|else|while|for)\\b"
                },
                {
                    "name": "keyword.control.memory.mc",
                    "match": "\\b(block|reset)\\b"
                },
                {
                    "name": "constant.language.mc",
                    "match": "\\b(true|false|null|error)\\b"
                }
            ]
        },
        "builtin-types": {
            "patterns": [
                {
                    "name": "storage.type.mc",
                    "match": "\\b(int|float|bool|char|String|void)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.mc",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.assignment.mc",
                    "match": "\\+=|-=|\\*=|/=|="
                },
                {
                    "name": "keyword.operator.comparison.mc",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.mc",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.mc",
                    "match": "\\+\\+|--|\\+|\\-|\\*|/"
                },
                {
                    "name": "keyword.operator.inc.mc",
                    "match": "\\+\\+|--"
                },
                {
                    "name": "keyword.operator.member.mc",
                    "match": "\\."
                },
                {
                    "name": "keyword.other.mc",
                    "match": ",|;|:"
                }
            ]
        },
        "at-annotation": {
            "patterns": [
                {
                    "name": "keyword.operator.at.mc",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "blocks-decl": {
            "patterns": [
                {
                    "name": "meta.block-declaration.mc",
                    "begin": "\\b(block)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.memory.mc" },
                        "2": { "name": "variable.name.block.mc" }
                    },
                    "end": "\\s*(KB|MB|GB)\\b",
                    "endCaptures": {
                        "1": { "name": "keyword.other.unit.mc" }
                    },
                    "patterns": [
                        { "include": "#numbers" }
                    ]
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.type.struct.mc",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                },
                {
                    "name": "variable.other.mc",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
